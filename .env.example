# For LOCAL DEV (NestJS on your machine, Postgres in Docker via docker-compose.db.yml)
# Run: docker compose -f docker-compose.db.yml up -d
# Then: pnpm start:dev
DATABASE_URL=postgresql://postgres:postgres@localhost:5434/crmp
JWT_SECRET=your-secret-key-here-change-in-production
JWT_EXPIRATION_MS=3600000
BCRYPT_ROUNDS=10
PORT=3000
NODE_ENV=development

# Mail Configuration
MAIL_HOST=smtp-relay.brevo.com
MAIL_PORT=587
MAIL_USER=your-verified-brevo-email@example.com
MAIL_PASS=your_brevo_smtp_password_or_key
MAIL_FROM=your-verified-brevo-email@example.com

# Redis Configuration (for Socket.IO adapters and BullMQ queues)
REDIS_URL=redis://localhost:6379

# Invitation Configuration
INVITATION_ACCEPT_URL=http://localhost:3000/auth/invitations
