# For LOCAL DEV (NestJS on your machine, Postgres in Docker via docker-compose.db.yml)
# Run: docker compose -f docker-compose.db.yml up -d
# Then: pnpm start:dev
DATABASE_URL=postgresql://postgres:postgres@localhost:5434/crmp
JWT_SECRET=your-secret-key-here-change-in-production
JWT_EXPIRATION_MS=3600000
BCRYPT_ROUNDS=10
PORT=3000
NODE_ENV=development